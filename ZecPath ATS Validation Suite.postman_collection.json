  "item": [
    {
      "name": "User Login - Valid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Ensure the request successfully returned a 200 OK status code\r",
              "if (pm.response.code === 200) {\r",
              "    \r",
              "    // 2. Parse the incoming JSON response body from your Django server\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    // 3. Extract the 'access' token string from the SimpleJWT response\r",
              "    const token = responseData.access;\r",
              "    \r",
              "    if (token) {\r",
              "        // 4. Automatically save the token into your active ZecPath-Local environment\r",
              "        pm.environment.set(\"accessToken\", token);\r",
              "        console.log(\"🚀 Success: Fresh Access Token saved to environment variables!\");\r",
              "    } else {\r",
              "        console.error(\"❌ Error: 'access' token key not found in the response body.\");\r",
              "    }\r",
              "} else {\r",
              "    console.warn(\"⚠️ Warning: Login failed with status code \" + pm.response.code);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"breakthrough_candidate@zecpath.com\",\r\n    \"password\": \"CandidatePassword123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login",
            ""
          ]
        }
      },
      "response": []
